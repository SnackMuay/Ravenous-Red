raw `

SandsweptCavern_North_MapScripts::
	.byte 0

`

script SandsweptCavern_EventScript_Melody{
    trainerbattle_single(TRAINER_COOLTRAINER_MELODY, Melody_Intro, Melody_Outro)
    msgbox(Melody_Postbattle, MSGBOX_AUTOCLOSE)
    waitmessage
    releaseall
}

text Melody_Intro{
    format("I keep getting sand in my shoes...")
}

text Melody_Outro{
    format("I would've won if it weren't for this sand distracting me.")
}

text Melody_Postbattle{
    format("I come here to train my POKéMON, but I have to constantly replace my wardrobe.")
}

