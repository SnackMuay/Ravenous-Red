script SandsweptCavern_EventScript_OldMan{
    lockall
    faceplayer
    goto_if_unset(FLAG_RECEIVED_TM21_SANDSWEPT, SandsweptCavern_EventScript_GivePerishSong)
    msgbox(format("Remember; our time is always limited, even when we don't realize it."))
    releaseall
}

script SandsweptCavern_EventScript_GivePerishSong{
    msgbox(format("The falling sand here in SANDSWEPT CAVERN always leaves me breathless.
        I can't help but imagine the grains of sand in an hourglass slowly dwindling
        as time marches forward. 
        Sooner than you realize, you'll be my age. 
        My favorite POKéMON MOVE perfectly encapsulates this theme as well. You ought to try it yourself."))
    giveitem(ITEM_TM21, amount=1)
    setflag(FLAG_RECEIVED_TM21_SANDSWEPT)
    msgbox(format("That TM contains PERISH SONG. Remember; our time is always limited, even when we don't realize it."))
    releaseall
}

