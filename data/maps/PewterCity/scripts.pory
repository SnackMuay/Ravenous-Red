`
text PewterCity_Text_BrocksLookingForChallengersFollowMe{
    format("You're a Trainer, right? Our town is being terrorized by some nefarious-looking folks. I hate to ask this, but I don't think we have any other choice. Follow me, I'll show you the people I'm talking about.")
}

text PewterCity_Text_GoTakeOnBrock{
    format("Our town would be indebted to you if you could save our citizens from these goons.")
}

script PewterCity_EventScript_Youngster{
    lock
	faceplayer
	textcolor(NPC_TEXT_COLOR_MALE)
    msgbox(format("I'm waiting for BROCK to return so that I can challenge the GYM. One of the early GYM TRAINERS defeated me on my last attempt, so I've added a WATER type to my team."))
    waitmessage
	msgbox(format("Wanna battle me while we wait for BROCK to return?"), MSGBOX_YESNO)
	goto_if_eq(VAR_RESULT, YES, PewterCity_EventScript_Hudson)
	goto_if_eq(VAR_RESULT, NO, PewterCity_EventScript_DeclineToBattle)
	closemessage
	face_up
	releaseall
}

script PewterCity_EventScript_Hudson{
	cleartrainerflag(TRAINER_YOUNGSTER_HUDSON)
	trainerbattle_single(TRAINER_YOUNGSTER_HUDSON, Hudson_Intro, Hudson_Outro)
	msgbox(Hudson_Postbattle, MSGBOX_AUTOCLOSE)
	waitmessage
	end
}

script PewterCity_EventScript_DeclineToBattle{
	lockall
	msgbox(format("Fine then. You're probably not even good practice."))
	waitmessage
	closemessage
	face_up
	releaseall
}

text Hudson_Intro{
	format("Let's go! My new team composition is sure to win!")
}

text Hudson_Outro{
	format("How could I lose?")
}

text Hudson_Postbattle{
	format("You might be even stronger than BROCK. There's no way that my POKéMON are still too weak to defeat a GYM.")
}

script PewterCity_EventScript_Museum_Grunt{
    lock
	faceplayer
    msgbox(format("No one's allowed in here. Boss's orders."))
	waitmessage
	closemessage
	face_down
    releaseall
}

script PewterCity_EventScript_Grunt_56{
	trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_56, Grunt_56_Intro, Grunt_56_Outro)
    msgbox(Grunt_56_Postbattle, MSGBOX_AUTOCLOSE)
    waitmessage
    end
}

text Grunt_56_Intro{
    format("You must be that kid I heard about from Viridian forest.")
}

text Grunt_56_Outro{
    format("Unbelievable.")
}

text Grunt_56_Postbattle{
    format("TEAM ROCKET won't be stopped by the likes of you.")
}

script PewterCity_EventScript_Grunt_57{
	trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_57, Grunt_57_Intro, Grunt_57_Outro)
    msgbox(Grunt_57_Postbattle, MSGBOX_AUTOCLOSE)
    waitmessage
    end
}

text Grunt_57_Intro{
    format("You've just made a big mistake.")
}

text Grunt_57_Outro{
    format("...What just happened?")
}

text Grunt_57_Postbattle{
    format("It's foolish to try and intervene here.")
}

script PewterCity_EventScript_Grunt_58{
	trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_58, Grunt_58_Intro, Grunt_58_Outro)
    msgbox(Grunt_58_Postbattle, MSGBOX_AUTOCLOSE)
    waitmessage
    end
}

text Grunt_58_Intro{
    format("My lucky day!")
}

text Grunt_58_Outro{
    format("How lame.")
}

text Grunt_58_Postbattle{
    format("I don't understand. SIMONE said that she defeated you with ease...")
}

script PewterCity_EventScript_Grunts_1{
	trainerbattle_double(TRAINER_TEAM_ROCKET_GRUNTS_1, Grunts_1_Intro, Grunts_1_Outro, Grunts_1_CantBattle, Grunts_1_Defeated)
    lockall
    msgbox(Grunts_1_Postbattle)
    waitmessage
    setvar(VAR_MAP_SCENE_PEWTER_CITY, 1)
    setvar(VAR_PEWTER_GRUNTS, 1)
    setflag(FLAG_GRUNTS_1)
    setflag(FLAG_HIDE_PEWTER_CITY_GYM_GUIDE)
    releaseall
}

script Grunts_1_Defeated{
	lockall
    msgbox(Grunts_1_Postbattle)
    waitmessage
    fadescreenswapbuffers(FADE_TO_BLACK)
    removeobject(LOCALID_GRUNT_F)
    removeobject(LOCALID_GRUNT_M)
    removeobject(LOCALID_GRUNT_58)
    removeobject(LOCALID_GRUNT_57)
    removeobject(LOCALID_GRUNT_56)
    setvar(VAR_MAP_SCENE_PEWTER_CITY, 1)
    setvar(VAR_PEWTER_GRUNTS, 1)
    setflag(FLAG_GRUNTS_1)
    setflag(FLAG_HIDE_PEWTER_CITY_GYM_GUIDE)
	callnative(UpdateFollowingPokemon)
    fadescreenswapbuffers(FADE_FROM_BLACK)
    releaseall
}

text Grunts_1_Intro{
    format("You've crossed us for the last time!")
}

text Grunts_1_Outro{
    format("This is unacceptable.")
}

text Grunts_1_CantBattle{
    format("You're too short-handed to take us on, kid.")
}

text Grunts_1_Postbattle{
    format("Maybe there won't be any meddling children in MT. MOON where the fossils are sourced. We ought to try that approach.")
}

script PewterCity_Trigger_BlockPath{
    lockall
    msgbox(format("{PLAYER} thought to themself: I should see if VIRIDIAN GYM is unlocked."))
    applymovement(OBJ_EVENT_ID_PLAYER, StopPlayer)
    waitmovement(0)
    releaseall
}

movement StopPlayer{
    walk_left
}

script PewterCity_Trigger_Grunts_West{
    lockall
    applymovement(LOCALID_GRUNT_F, FaceLeft)
    waitmovement(0)
    applymovement(LOCALID_GRUNT_M, WestTrigger)
    waitmovement(4)
    trainerbattle_double(TRAINER_TEAM_ROCKET_GRUNTS_1, Grunts_1_Intro, Grunts_1_Outro, Grunts_1_CantBattle, Grunts_1_Defeated)
    releaseall
}

movement FaceLeft{
    face_left
}

movement FaceDown{
    face_down
}

movement WestTrigger{
    faceplayer
    walk_left
}

script PewterCity_Trigger_Grunts_East{
    lockall
    applymovement(LOCALID_GRUNT_F, EastTrigger)
    waitmovement(4)
    applymovement(LOCALID_GRUNT_M, FaceDown)
    waitmovement(0)
    trainerbattle_double(TRAINER_TEAM_ROCKET_GRUNTS_1, Grunts_1_Intro, Grunts_1_Outro, Grunts_1_CantBattle, Grunts_1_Defeated)
    releaseall
}

movement EastTrigger{
    faceplayer
    walk_down
}

script PewterCity_Trigger_Grunts_Middle{
    lockall
    applymovement(LOCALID_GRUNT_F, FaceDown)
    waitmovement(0)
    applymovement(LOCALID_GRUNT_M, FaceLeft)
    waitmovement(0)
    trainerbattle_double(TRAINER_TEAM_ROCKET_GRUNTS_1, Grunts_1_Intro, Grunts_1_Outro, Grunts_1_CantBattle, Grunts_1_Defeated)
    releaseall
}

script PewterCity_EventScript_Scientist{
	lockall
	faceplayer
	msgbox(format("Thank you so much! I was just seconds away from being overwhelmed. It hurts to imagine people out there using their POKéMON to harm others. 
		Come visit me on the second floor of PEWTER MUSEUM. I'd like to give you a token of my gratitude."))
	fadescreenswapbuffers(FADE_TO_BLACK)
	removeobject(LOCALID_PEWTER_SCIENTIST)
	setflag(FLAG_SPOKEN_WITH_SCIENTIST)
	callnative(UpdateFollowingPokemon)
	fadescreenswapbuffers(FADE_FROM_BLACK)
	releaseall
}

