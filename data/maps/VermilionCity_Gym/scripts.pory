script VermilionCity_Gym_EventScript_BrooksRefuse{
    msgbox(Brooks_PostBattle, MSGBOX_AUTOCLOSE)
    releaseall
}

text Brooks_Intro{
    format("If you think you can win, you're in for quite a shock!")
}

text Brooks_Outro{
    format("I'm completely zapped.")
}

text Brooks_PostBattle{
    format("LT. SURGE uses ELECTRIC POKéMON much better than I can. Maybe one day he'll coach me.")
}

script VermilionCity_Gym_EventScript_Hazel{
	trainerbattle_single(TRAINER_AROMA_LADY_HAZEL, Hazel_Intro, Hazel_Outro)
    msgbox(format("Would you like me to heal your party?"), MSGBOX_YESNO)
    goto_if_eq(VAR_RESULT, YES, VermilionCity_Gym_EventScript_HazelAccept)
	goto_if_eq(VAR_RESULT, NO, VermilionCity_Gym_EventScript_HazelRefuse)
	releaseall
}

script VermilionCity_Gym_EventScript_HazelAccept{
    msgbox(format("As you wish."))
	call(EventScript_OutOfCenterPartyHeal)
    msgbox(Hazel_PostBattle, MSGBOX_AUTOCLOSE)
    releaseall
}

script VermilionCity_Gym_EventScript_HazelRefuse{
    msgbox(Hazel_PostBattle, MSGBOX_AUTOCLOSE)
    releaseall
}

text Hazel_Intro{
    format("Oh! Yeah, I'm supposed to battle you now.")
}

text Hazel_Outro{
    format("That was stressful.")
}

text Hazel_PostBattle{
    format("Honestly, I can't figure out why LT. SURGE insists on my being here.")
}

text VermilionCity_Gym_TrashSwitch{
    format("Hey, there's a switch under the trash! {PLAYER} turned the switch off.")
}


