text Tucker_Intro{
    format("Listen here, kid!")
}

text Tucker_Outro{
    format("You shredded us.")
}

text Tucker_PostBattle{
    format("POKéMON work together like the members of a rock band. 
        Speed control POKéMON are the drums, they set the rhythm. 
        POKéMON with great defense are like the bass guitar, unwavering. 
        The vocalist? that's the star of the show! 
        POKéMON who are able to land KO's and sweep other teams are the frontmen.")
}

