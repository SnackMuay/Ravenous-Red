script ViridianForest_Annex_EventScript_Simone_1{
	trainerbattle_single(TRAINER_TEAM_ROCKET_ADMIN_SIMONE_1, Simone_1_Intro, Simone_1_Outro, Simone_1_Defeated,)
    lockall
    textcolor(NPC_TEXT_COLOR_FEMALE)
    msgbox(Simone_1_Postbattle)
    waitmessage
    releaseall
}

text Simone_1_Intro{
    format("I'll teach you not to mess with Team Rocket.")
}

text Simone_1_Outro{
    format("That's it, we're leaving. GIOVANNI won't be happy about this.")
}
text Simone_1_Postbattle{
    format("...")
}

script Simone_1_Defeated{
    msgbox(format("..."))
    waitmessage
    closemessage
    fadescreen(FADE_TO_BLACK)
    removeobject(LOCALID_GRUNT_52)
	removeobject(LOCALID_GRUNT_53)
    removeobject(LOCALID_GRUNT_54)
    removeobject(LOCALID_GRUNT_55)
    removeobject(LOCALID_VIRIDIAN_SIMONE)
    setflag(FLAG_SIMONE_1)
    fadescreen(FADE_FROM_BLACK)
    releaseall
}

script ViridianForest_Annex_Eventscript_Scientist{
    lockall
    faceplayer
    msgbox(format("Thank you for saving me! You got here just in time for me to prevent my fossils from being stolen by those goons. They said something about heading to Pewter City. I wouldn't be shocked if they intend to terrorize the scientists there too!"))
    waitmessage
    releaseall
}

script Viridian_Forest_Grunts_Trigger{
    lockall
    applymovement(LOCALID_GRUNT_54, GruntMovement)
    waitmovement(0)
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_54, Grunt_54_Intro, Grunt_54_Outro, Viridian_Forest_Grunts_Trigger_cont)
    releaseall
}

script Viridian_Forest_Grunts_Trigger_cont{
    applymovement(LOCALID_GRUNT_55, GruntMovement)
    waitmovement(0)
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_55, Grunt_55_Intro, Grunt_55_Outro, Viridian_Forest_Grunts_Defeated)
    releaseall
}

script Viridian_Forest_Grunts_Defeated{
    setvar(VAR_SIMONE_1_ANNEX, 1)
    releaseall
}

movement GruntMovement{
    walk_left
    faceplayer
}

text Grunt_54_Intro{
    format("That's it. Your fun little adventure ends here.")
}

text Grunt_54_Outro{
    format("Must be your lucky day.")
}

text Grunt_54_Postbattle{
    format("Don't be stupid. You're no match for SIMONE.")
}

text Grunt_55_Intro{
    format("I'll handle this.")
}

text Grunt_55_Outro{
    format("Fine. SIMONE will straighten you out.")
}

text Grunt_55_Postbattle{
    format("I dare you to continue this meddling. Our boss won't be so patient with you.")
}
