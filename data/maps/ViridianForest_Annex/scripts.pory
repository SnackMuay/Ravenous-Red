mapscripts ViridianForest_Annex_MapScripts {}



script ViridianForest_Annex_EventScript_Manuel{
	trainerbattle_single(TRAINER_BUG_CATCHER_MANUEL, Manuel_Intro, Manuel_Outro)
    msgbox(Manuel_Postbattle, MSGBOX_AUTOCLOSE)
    waitmessage
    end
}

text Manuel_Intro{
    format("Bugs! Together! Strong!")
}

text Manuel_Outro{
    format("My POKéMON didn't work together how I expected them to.")
}

text Manuel_Postbattle{
    format("I hope to one day be a skillful POKéMON trainer like Bugsy. That's why I'm training here in Viridian Forest.")
}

script ViridianForest_Annex_EventScript_Claudia{
	trainerbattle_single(TRAINER_PICNICKER_CLAUDIA, Claudia_Intro, Claudia_Outro)
    msgbox(Claudia_Postbattle, MSGBOX_AUTOCLOSE)
    waitmessage
    end
}

text Claudia_Intro{
    format("En garde!")
}

text Claudia_Outro{
    format("Touche.")
}

text Claudia_Postbattle{
    format("Here, deep in forest, I can best harness the awesome power of nature and her POKéMON.")
}

script ViridianForest_Annex_EventScript_Evie{
	trainerbattle_single(TRAINER_LASS_EVIE, Evie_Intro, Evie_Outro)
    msgbox(Evie_Postbattle, MSGBOX_AUTOCLOSE)
    waitmessage
    end
}

text Evie_Intro{
    format("Let's go!")
}

text Evie_Outro{
    format("...My POKéMON were still cuter than yours.")
}
text Evie_Postbattle{
    format("Even if they aren't the most powerful POKéMON, I love my precious EEVEE and PIKACHU.")
}

script ViridianForest_Annex_EventScript_Grunt_52{
	trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_52, Grunt_52_Intro, Grunt_52_Outro)
    msgbox(Grunt_52_Postbattle, MSGBOX_AUTOCLOSE)
    waitmessage
    end
}

text Grunt_52_Intro{
    format("Go be a pest somewhere else!")
}

text Grunt_52_Outro{
    format("I... lost? I lost to a kid?")
}
text Grunt_52_Postbattle{
    format("You'll get out of here if you know what's good for ya.")
}

