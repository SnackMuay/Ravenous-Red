script CloudedWood_EventScript_Aspen{
    trainerbattle_single(TRAINER_CHANNELER_ASPEN, Aspen_Intro, Aspen_Outro)
    msgbox(Aspen_Postbattle, MSGBOX_AUTOCLOSE)
    waitmessage
    end
}

text Aspen_Intro{
    format("Boo!")
}

text Aspen_Outro{
    format("You're scary.")
}

text Aspen_Postbattle{
    format("Do you feel that? This forest is connected to the other side.")
}

