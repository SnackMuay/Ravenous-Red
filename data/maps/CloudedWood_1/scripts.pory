script CloudedWood_EventScript_Agatha{
    lockall
    faceplayer
	textcolor(NPC_TEXT_COLOR_FEMALE)
    goto_if_unset(FLAG_GO_GOGGLES, CloudedWood_EventScript_Agatha_PreBattle)
    msgbox(format("GHOST-type POKéMON are my specialty, but like all members of the ELITE FOUR, 
        I am flexible enough to appreciate other POKéMON as well."))
    closemessage
    releaseall
}

script CloudedWood_EventScript_Agatha_PreBattle{
    faceplayer
    msgbox(format("You're {PLAYER}, aren't you? I hear OAK's taken a lot of interest in you, child.  
        Like me, his best days are behind him. But you might be surprised at how even this old bag can keep up 
        with you young ones. I've even developed an affinity for DOUBLE BATTLES."))
    waitmessage
	msgbox(format("What do you say, would you like to see if you've got what it takes to 
        defeat me?"), MSGBOX_YESNO)
	goto_if_eq(VAR_RESULT, YES, CloudedWood_EventScript_AgathaDouble)
	goto_if_eq(VAR_RESULT, NO, CloudedWood_EventScript_DeclineToBattle)
	closemessage
	face_down
	releaseall
}

script CloudedWood_EventScript_AgathaDouble{
	trainerbattle_double(TRAINER_CLOUDED_WOOD_AGATHA, Agatha_Intro, Agatha_Outro, Agatha_CantBattle, CloudedWood_Agatha_Defeated)
	msgbox(Agatha_Postbattle, MSGBOX_AUTOCLOSE)
	waitmessage
	end
}

script CloudedWood_EventScript_DeclineToBattle{
	lockall
	msgbox(format("No worries, dear. A former ELITE FOUR is a challenge that most TRAINERS shy away from."))
	waitmessage
	closemessage
	face_down
	releaseall
}

script CloudedWood_Agatha_Defeated{
	lockall
    msgbox(Agatha_Postbattle)
    waitmessage
    giveitem(ITEM_GO_GOGGLES, amount=1)
    setflag(FLAG_GO_GOGGLES)
    msgbox(format("Those ought to help you traverse the parts of KANTO with harsh weather."))
    releaseall
}

text Agatha_CantBattle{
    format("You don't have enough POKéMON with you to engage me in a DOUBLE BATTLE.")
}

text Agatha_Intro{
	format("Try to keep your bearings!")
}

text Agatha_Outro{
	format("OAK was right. You're quite the young TRAINER.")
}

text Agatha_Postbattle{
	format("I haven't encountered a TRAINER as promising as yourself in quite some time. I'd love to help your journey along.")
}

