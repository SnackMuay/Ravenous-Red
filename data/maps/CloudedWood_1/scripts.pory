script CloudedWood_EventScript_Woman1{
    lockall
    faceplayer
    msgbox(format("My girlfriend thinks I'm weird for this, but there's something about this place that calls to me."))
    releaseall
}

script CloudedWood_EventScript_Fisherman{
    lockall
    faceplayer
    msgbox(format("The stillness here in CLOUDED WOOD makes it a perfect spot for fishing."))
    releaseall
}
