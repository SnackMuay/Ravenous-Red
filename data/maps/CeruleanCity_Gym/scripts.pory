}

text Deejay_PostBattle{
    format("Choose your path wisely. Each trainer en route to MISTY presents a unique challenge.")
}

script CeruleanCity_Gym_EventScript_Ariel{
	trainerbattle_single(TRAINER_SWIMMER_FEMALE_ARIEL, Ariel_Intro, Ariel_Outro)
