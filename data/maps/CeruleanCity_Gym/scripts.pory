script CeruleanCity_Gym_EventScript_Chance{
	trainerbattle_single(TRAINER_SWIMMER_MALE_CHANCE, Chance_Intro, Chance_Outro)
    special(HealPlayerParty)
	msgbox(Chance_PostBattle, MSGBOX_AUTOCLOSE)
	releaseall
}

text Chance_Intro{
    format("Here goes!")
}

text Chance_Outro{
    format("I can't be upset having lost to a TRAINER of your caliber.")
}

text Chance_PostBattle{
    format("That was my best effort. You've proven that you're worthy to challenge this GYM's LEADER.")
}

script CeruleanCity_Gym_EventScript_BodyGuard{
    lockall
    faceplayer
    msgbox(format("MISTY doesn't need our protection. She's the most formidable TRAINER I've ever met."))
    releaseall
}
